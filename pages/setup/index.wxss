.container {
  min-height: 100vh;
  padding: 68rpx 44rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #FBF6EE;
}

.container > view {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo {
  display: block;
  font-size: 88rpx;
  margin-bottom: 20rpx;
}

.title {
  display: block;
  width: 100%;
  text-align: center;
  font-size: 52rpx;
  font-weight: 900;
  color: #2A1F10;
  letter-spacing: 3rpx;
  line-height: 1.05;
  margin-bottom: 14rpx;
}

.subtitle {
  display: block;
  width: 100%;
  text-align: center;
  font-size: 24rpx;
  color: #8F8577;
  line-height: 1.75;
  margin-bottom: 72rpx;
}

.card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 40rpx 36rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 1px solid rgba(42, 31, 16, 0.08);
  box-shadow: 0 10rpx 26rpx rgba(42, 31, 16, 0.08);
  box-sizing: border-box;
}

.card-emoji { font-size: 50rpx; }

.card-main {
  font-size: 30rpx;
  font-weight: 700;
  color: #2A1F10;
}

.card-sub {
  font-size: 22rpx;
  color: #8F8577;
  line-height: 1.6;
}

.code-box {
  width: 100%;
  background: #FFFFFF;
  border-radius: 30rpx;
  padding: 48rpx 36rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 42rpx;
  box-shadow: 0 10rpx 28rpx rgba(42, 31, 16, 0.08);
}

.code-label {
  font-size: 22rpx;
  color: #A89F92;
  letter-spacing: 1px;
}

.code-text {
  font-size: 64rpx;
  font-weight: 700;
  color: #2A1F10;
  letter-spacing: 10rpx;
}

.code-hint {
  font-size: 20rpx;
  color: #B0A995;
  text-align: center;
  line-height: 1.7;
}

.code-input,
.name-input {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 22rpx rgba(42, 31, 16, 0.08);
  box-sizing: border-box;
}

.code-input {
  padding: 34rpx 36rpx;
  font-size: 48rpx;
  font-weight: 700;
  color: #2A1F10;
  letter-spacing: 10rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.name-input {
  padding: 26rpx 34rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #2A1F10;
  text-align: center;
  margin-bottom: 18rpx;
}

.input-hint {
  font-size: 20rpx;
  color: #B3A894;
  margin-top: -10rpx;
  margin-bottom: 30rpx;
}

.name-label {
  display: block;
  width: 100%;
  font-size: 20rpx;
  color: #A89F92;
  text-align: left;
  margin-bottom: 10rpx;
  letter-spacing: 0.5rpx;
}

.date-picker-row {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 26rpx 28rpx;
  box-sizing: border-box;
  margin-bottom: 14rpx;
  border: 1rpx solid #EDE5D6;
}
.date-picker-icon { font-size: 32rpx; }
.date-picker-val {
  font-size: 30rpx;
  color: #3D3324;
  flex: 1;
}

.code-placeholder {
  color: #BBAAA0;
  font-size: 30rpx;
  font-weight: 400;
  letter-spacing: 3px;
}

.date-picker-placeholder {
  color: #BBAAA0;
}

.date-picker-change {
  font-size: 22rpx;
  color: #A89F92;
  background: #F0E8DC;
  border-radius: 20rpx;
  padding: 6rpx 18rpx;
}

.btn-primary {
  width: 100%;
  background: #F5C842;
  border-radius: 30rpx;
  padding: 32rpx 0;
  text-align: center;
  font-size: 30rpx;
  color: #2A1F10;
  font-weight: 700;
  box-sizing: border-box;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 24rpx rgba(245, 200, 66, 0.22);
}

.btn-primary.disabled {
  background: rgba(245, 200, 66, 0.5);
}

.btn-back {
  font-size: 24rpx;
  color: #9E8B7E;
  padding: 18rpx 0;
}

.error {
  font-size: 22rpx;
  color: #C4706A;
  text-align: center;
  margin-bottom: 24rpx;
}
