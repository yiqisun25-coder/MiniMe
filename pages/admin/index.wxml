<view class="container">

  <!-- 头像设置 -->
  <view class="avatar-section">
    <view class="avatar-wrap">
      <image class="avatar-img" src="{{avatarSrc}}" mode="aspectFill" />
    </view>
    <view class="avatar-upload-btn {{avatarUploading ? 'uploading' : ''}}" bindtap="uploadAvatar">
      <text>{{avatarUploading ? '上传中…' : '更换头像'}}</text>
    </view>
    <view class="name-edit-row">
      <text class="name-edit-label">妈妈叫我</text>
      <input class="name-edit-input" value="{{daughterName}}" bindinput="onNameInput"
             placeholder="比如 祎琦" placeholder-class="name-placeholder" maxlength="10" />
    </view>
    <view class="name-edit-row">
      <text class="name-edit-label">我叫妈妈</text>
      <input class="name-edit-input" value="{{momName}}" bindinput="onMomNameInput"
             placeholder="比如 妈妈" placeholder-class="name-placeholder" maxlength="10" />
      <view class="name-save-btn" bindtap="saveName"><text>保存</text></view>
    </view>
  </view>

  <!-- 家庭邀请码 -->
  <view class="invite-box" wx:if="{{familyCode}}">
    <text class="invite-label">家庭邀请码</text>
    <text class="invite-code">{{familyCode}}</text>
    <text class="invite-hint">把这个码发给妈妈，她输入后就连上了</text>
    <text class="invite-unbind" bindtap="onUnbindTap">解绑退出这个家庭</text>
  </view>

  <!-- 妈妈的留言 -->
  <view class="toolbar">
    <text class="toolbar-title">
      妈妈的留言{{unreadCount > 0 ? '（' + unreadCount + '条未读）' : ''}}
    </text>
    <view class="mark-btn" bindtap="markAllRead" wx:if="{{unreadCount > 0}}">
      <text>全部已读</text>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text class="loading-text">加载中…</text>
  </view>

  <view wx:elif="{{messages.length === 0}}" class="empty-small">
    <text class="empty-text">妈妈还没有留言</text>
  </view>

  <view wx:else>
    <view wx:for="{{messages}}" wx:key="id" class="msg-card {{!item.readByYiqi ? 'unread' : ''}}">
      <view class="msg-top">
        <view class="unread-dot" wx:if="{{!item.readByYiqi}}"></view>
        <text class="msg-time">{{item.timeStr}}</text>
      </view>
      <text class="msg-text">{{item.text}}</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="action-row">
    <view class="action-btn" bindtap="goCompose">
      <text class="action-emoji">✏️</text>
      <text class="action-label">给妈妈写信</text>
    </view>
    <view class="action-btn" bindtap="goDaily">
      <text class="action-emoji">📝</text>
      <text class="action-label">存我的日常</text>
    </view>
    <view class="action-btn" bindtap="goMemory">
      <text class="action-emoji">🔒</text>
      <text class="action-label">预存记忆</text>
    </view>
  </view>

  <!-- 我发出去的 -->
  <view class="section-title">我发出去的</view>

  <view class="tab-bar">
    <view class="tab {{activeTab === 'daily' ? 'active' : ''}}" data-tab="daily" bindtap="switchTab">
      <text>日常 ({{dailyList.length}})</text>
    </view>
    <view class="tab {{activeTab === 'memory' ? 'active' : ''}}" data-tab="memory" bindtap="switchTab">
      <text>记忆锁 ({{memoryList.length}})</text>
    </view>
    <view class="tab {{activeTab === 'letter' ? 'active' : ''}}" data-tab="letter" bindtap="switchTab">
      <text>信 ({{letterList.length}})</text>
    </view>
  </view>

  <!-- 日常列表 -->
  <view wx:if="{{activeTab === 'daily'}}">
    <view class="empty-small" wx:if="{{dailyList.length === 0}}">
      <text class="empty-text">还没有日常记录</text>
    </view>
    <view wx:for="{{dailyList}}" wx:key="id" class="item-card">
      <view wx:if="{{editingId !== item.id}}">
        <text class="item-time">{{item.timeStr}}</text>
        <text class="item-text">{{item.text}}</text>
        <view class="item-actions">
          <view class="btn-edit" data-id="{{item.id}}" bindtap="startEdit"><text>✏️ 编辑</text></view>
          <view class="btn-delete" data-id="{{item.id}}" data-type="daily" bindtap="deleteItem"><text>删除</text></view>
        </view>
      </view>
      <view wx:else>
        <textarea class="edit-textarea" value="{{editingText}}" bindinput="onEditInput" auto-height maxlength="500" />
        <view class="date-row">
          <picker mode="date" value="{{editingDate}}" end="{{today}}" bindchange="onEditDateChange">
            <view class="date-picker-btn">
              <text class="date-icon">📅</text>
              <text class="date-text">{{editingDate}}</text>
            </view>
          </picker>
          <picker mode="time" value="{{editingTime}}" bindchange="onEditTimeChange">
            <view class="date-picker-btn">
              <text class="date-icon">🕐</text>
              <text class="date-text">{{editingTime}}</text>
            </view>
          </picker>
        </view>
        <view class="edit-actions">
          <view class="btn-cancel" bindtap="cancelEdit"><text>取消</text></view>
          <view class="btn-save" bindtap="saveEdit"><text>保存</text></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 记忆锁列表 -->
  <view wx:if="{{activeTab === 'memory'}}">
    <view class="empty-small" wx:if="{{memoryList.length === 0}}">
      <text class="empty-text">还没有预存记忆</text>
    </view>
    <view wx:for="{{memoryList}}" wx:key="id" class="item-card">
      <text class="item-time">🔒 {{item.unlockDate}} 解锁</text>
      <text class="item-title">{{item.title}}</text>
      <text class="item-text">{{item.text}}</text>
      <view class="item-actions">
        <view class="btn-delete" data-id="{{item.id}}" data-type="memory" bindtap="deleteItem"><text>删除</text></view>
      </view>
    </view>
  </view>

  <!-- 信列表 -->
  <view wx:if="{{activeTab === 'letter'}}">
    <view class="empty-small" wx:if="{{letterList.length === 0}}">
      <text class="empty-text">还没有写过信</text>
    </view>
    <view wx:for="{{letterList}}" wx:key="id" class="item-card">
      <text class="item-time">{{item.timeStr}}{{item.readByMom ? ' · 已读' : ' · 未读'}}</text>
      <text class="item-title">{{item.title}}</text>
      <text class="item-text">{{item.text}}</text>
      <view class="item-actions">
        <view class="btn-delete" data-id="{{item.id}}" data-type="letter" bindtap="deleteItem"><text>删除</text></view>
      </view>
    </view>
  </view>

</view>
