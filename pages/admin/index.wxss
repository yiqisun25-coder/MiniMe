.container {
  padding: 40rpx 40rpx 160rpx;

  min-height: 100vh;
  box-sizing: border-box;
}

/* ── 头像设置 ── */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
}

.avatar-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx solid rgba(42, 31, 16, 0.12);
  box-shadow: 0 4rpx 20rpx rgba(42, 31, 16, 0.1);
  margin-bottom: 20rpx;
}

.avatar-img { width: 100%; height: 100%; }

.avatar-upload-btn {
  background: rgba(45, 57, 38, 0.08);
  border-radius: 12rpx;
  padding: 14rpx 36rpx;
  font-size: 24rpx;
  color: #2D3926;
}

.avatar-upload-btn.uploading {
  opacity: 0.5;
}

.name-edit-row {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  width: 100%;
}

.name-edit-label {
  font-size: 22rpx;
  color: #9E8B7E;
  flex-shrink: 0;
  margin-right: 16rpx;
  white-space: nowrap;
}

.name-edit-input {
  flex: 1;
  background: #fff;
  border-radius: 14rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #2A1F10;
  box-sizing: border-box;
  margin-right: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(42, 31, 16, 0.06);
}

.name-placeholder { color: #D8C8BE; }

.name-save-btn {
  background: #2D3926;
  border-radius: 12rpx;
  padding: 16rpx 28rpx;
  font-size: 24rpx;
  color: #F3E8D4;
  flex-shrink: 0;
}

/* ── 邀请码 ── */
.invite-box {
  background: #FFFCF7;
  border-radius: 20rpx;
  padding: 36rpx 40rpx;
  margin-bottom: 36rpx;
  border: 1rpx solid rgba(42,31,16,0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.invite-label { font-size: 22rpx; color: #9E8B7E; letter-spacing: 2rpx; }
.invite-code  { font-size: 56rpx; font-weight: 700; color: #2A1F10; letter-spacing: 10rpx; }
.invite-hint  { font-size: 22rpx; color: #C8B8AF; text-align: center; }
.invite-unbind {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #C4706A;
  text-decoration: underline;
  padding: 8rpx 16rpx;
}

/* ── 妈妈留言 ── */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.toolbar-title { font-size: 28rpx; color: #3D2B1F; font-weight: 600; }

.mark-btn {
  background: #F4A261;
  border-radius: 12rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #fff;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}
.loading-text { font-size: 28rpx; color: #9E8B7E; }

.msg-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.msg-card.unread { border-left: 5rpx solid #F4A261; }

.msg-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.unread-dot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  background: #F4A261;
  flex-shrink: 0;
}
.msg-time { font-size: 22rpx; color: #C8B8AF; }
.msg-text { font-size: 29rpx; color: #3D2B1F; line-height: 1.7; white-space: pre-wrap; }

/* ── 快捷入口 ── */
.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 36rpx;
}
.action-btn {
  flex: 1;
  background: rgba(255,252,247,0.9);
  border-radius: 20rpx;
  padding: 28rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  border: 1rpx solid rgba(42,31,16,0.1);
  box-shadow: 0 2rpx 10rpx rgba(42,31,16,0.04);
}
.action-emoji { font-size: 38rpx; }
.action-label { font-size: 23rpx; color: #2A1F10; }

/* ── 我发出去的 ── */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2B1F;
  margin: 48rpx 0 20rpx;
  padding-top: 40rpx;
  border-top: 1rpx solid rgba(42,31,16,0.08);
}

.tab-bar {
  display: flex;
  background: rgba(42,31,16,0.06);
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  font-size: 25rpx;
  color: #9E8B7E;
}
.tab.active {
  background: #fff;
  color: #2A1F10;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(42,31,16,0.1);
}

/* ── 条目卡片 ── */
.item-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.item-time {
  display: block;
  font-size: 22rpx;
  color: #C8B8AF;
  margin-bottom: 10rpx;
}
.item-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2A1F10;
  margin-bottom: 8rpx;
}
.item-text {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  font-size: 28rpx;
  color: #5A4A38;
  line-height: 1.7;
  white-space: pre-wrap;
}

.item-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(42,31,16,0.06);
}
.btn-edit   { font-size: 24rpx; color: #9E8B7E; }
.btn-delete { font-size: 24rpx; color: #C4706A; }

/* ── 编辑态 ── */
.edit-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #2A1F10;
  line-height: 1.75;
  box-sizing: border-box;
  border-bottom: 1rpx solid rgba(42,31,16,0.1);
  padding-bottom: 12rpx;
}
.date-row { display: flex; gap: 12rpx; margin: 16rpx 0 4rpx; }
.date-picker-btn {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(42,31,16,0.04);
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
}
.date-icon { font-size: 24rpx; }
.date-text { font-size: 24rpx; color: #2A1F10; }

.edit-actions { display: flex; gap: 16rpx; margin-top: 16rpx; }
.btn-cancel, .btn-save {
  flex: 1;
  text-align: center;
  border-radius: 12rpx;
  padding: 18rpx 0;
  font-size: 26rpx;
}
.btn-cancel { background: rgba(200,184,175,0.2); color: #9E8B7E; }
.btn-save   { background: #2D3926; color: #F3E8D4; }

/* ── 空状态 ── */
.empty-small {
  padding: 40rpx 0;
  text-align: center;
}
.empty-small .empty-text {
  font-size: 26rpx;
  color: #C8B8AF;
}
