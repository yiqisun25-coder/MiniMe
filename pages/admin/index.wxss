.container {
  padding: 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.toolbar-title { font-size: 28rpx; color: #3D2B1F; font-weight: 600; }

.mark-btn {
  background: #F4A261;
  border-radius: 12rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #fff;
}

.loading, .empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  gap: 24rpx;
}
.loading-text, .empty-text { font-size: 28rpx; color: #9E8B7E; }
.empty-icon { font-size: 80rpx; }

.msg-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 36rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.msg-card.unread { border-left: 6rpx solid #F4A261; }

.msg-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.unread-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #F4A261;
  flex-shrink: 0;
}

.msg-time { font-size: 24rpx; color: #C8B8AF; }

.msg-text {
  font-size: 30rpx;
  color: #3D2B1F;
  line-height: 1.7;
  white-space: pre-wrap;
}

.action-row {
  margin-top: 48rpx;
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  background: rgba(255,252,247,0.85);
  border-radius: 20rpx;
  padding: 30rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  border: 1rpx solid rgba(42,31,16,0.1);
  box-shadow: 0 2rpx 12rpx rgba(42,31,16,0.04);
}

.action-emoji { font-size: 40rpx; }
.action-label { font-size: 24rpx; color: #2A1F10; }
