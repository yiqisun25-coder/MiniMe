/* ══ 开屏 ══ */
.splash {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 999;
}
.splash-in  { animation: splashIn  0.5s ease forwards; }
.splash-out { animation: splashOut 0.5s ease forwards; }
@keyframes splashIn  { from { opacity: 0; } to { opacity: 1; } }
@keyframes splashOut { from { opacity: 1; } to { opacity: 0; } }

/* 背景渐变 */
.splash-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(180deg, #FDE9A0 0%, #FEF3C8 28%, #FAFAEC 52%, #EFF5DA 76%, #DDEAB8 100%);
  overflow: hidden;
}

/* ── 太阳（用大容器居中，光芒绕中心旋转）── */
.s-sun {
  position: absolute;
  top: 60rpx;
  left: 50%;
  /* 容器 440rpx，居中偏移 220rpx */
  margin-left: -220rpx;
  width: 440rpx; height: 440rpx;
}
/* 光芒：每根以太阳中心(220,220)为轴旋转 */
.s-ray {
  position: absolute;
  width: 16rpx; height: 56rpx;
  /* 水平居中于容器，顶部距容器顶 16rpx（在太阳圆圈外） */
  left: 212rpx; top: 16rpx;
  background: #F5D020;
  border-radius: 10rpx;
  opacity: 0.75;
  /* transform-origin 距顶端 204rpx = 到容器中心 220-16=204 */
  transform-origin: 8rpx 204rpx;
}
.s-ray-1 { transform: rotate(0deg); }
.s-ray-2 { transform: rotate(45deg); }
.s-ray-3 { transform: rotate(90deg); }
.s-ray-4 { transform: rotate(135deg); }
.s-ray-5 { transform: rotate(180deg); }
.s-ray-6 { transform: rotate(225deg); }
.s-ray-7 { transform: rotate(270deg); }
.s-ray-8 { transform: rotate(315deg); }

/* 太阳脸：直径 200rpx，居中于容器 */
.s-sun-face {
  position: absolute;
  top: 120rpx; left: 120rpx;
  width: 200rpx; height: 200rpx;
  border-radius: 50%;
  background: #F5C842;
  box-shadow: 0 0 60rpx rgba(245,200,66,0.55);
  overflow: hidden;
}
.s-eye {
  position: absolute;
  top: 72rpx;
  width: 26rpx; height: 18rpx;
  border-radius: 50%;
  background: rgba(168, 90, 20, 0.35);
}
.s-eye-l { left: 34rpx; }
.s-eye-r { right: 54rpx; }
.s-smile {
  position: absolute;
  bottom: 52rpx; left: 50%;
  transform: translateX(-70%);
  width: 36rpx; height: 18rpx;
  background: rgba(168, 90, 20, 0.32);
  border-radius: 0 0 36rpx 36rpx;
}

/* ── 云朵 ── */
.s-cloud { position: absolute; }
.s-cloud-body {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 44rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 22rpx;
}
.s-cloud-puff {
  position: absolute;
  background: rgba(255,255,255,0.9);
  border-radius: 50%;
}
.s-cloud-1 { top: 280rpx; left: 40rpx; width: 150rpx; height: 72rpx; }
.s-cloud-1 .s-puff-1 { width: 68rpx; height: 68rpx; bottom: 22rpx; left: 14rpx; }
.s-cloud-1 .s-puff-2 { width: 52rpx; height: 52rpx; bottom: 22rpx; right: 16rpx; }
.s-cloud-2 { top: 240rpx; right: 50rpx; width: 120rpx; height: 58rpx; }
.s-cloud-2 .s-puff-1 { width: 54rpx; height: 54rpx; bottom: 18rpx; left: 10rpx; }
.s-cloud-2 .s-puff-2 { width: 40rpx; height: 40rpx; bottom: 18rpx; right: 12rpx; }

/* ── 山丘（7层，含阴影） ── */
.s-hills {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 560rpx;
}
.s-hill { position: absolute; border-radius: 50%; }

/* 最远层：最浅，模拟远山 */
.s-hill-far-l {
  bottom: -160rpx; left: -200rpx;
  width: 520rpx; height: 360rpx;
  background: #DFF0BE;
}
.s-hill-far-r {
  bottom: -140rpx; right: -180rpx;
  width: 500rpx; height: 340rpx;
  background: #E2F2C2;
}
/* 中层：稍深 */
.s-hill-mid-l {
  bottom: -230rpx; left: -120rpx;
  width: 700rpx; height: 460rpx;
  background: #C2DC98;
}
.s-hill-mid-r {
  bottom: -250rpx; right: -100rpx;
  width: 660rpx; height: 440rpx;
  background: #C8E09E;
}
/* 前景主山 */
.s-hill-front {
  bottom: -310rpx; left: -80rpx;
  width: 940rpx; height: 560rpx;
  background: #A8CC78;
}
/* 阴影层：深色叠在前景左右侧，模拟侧面阴影 */
.s-hill-shadow-l {
  bottom: -340rpx; left: -180rpx;
  width: 560rpx; height: 500rpx;
  background: #8AB85E;
  opacity: 0.45;
}
.s-hill-shadow-r {
  bottom: -360rpx; right: -160rpx;
  width: 520rpx; height: 480rpx;
  background: #8AB85E;
  opacity: 0.4;
}

/* ── 树 ── */
.s-tree { position: absolute; }
.s-tree-l { bottom: 260rpx; left: 64rpx; width: 88rpx; height: 140rpx; }
.s-tree-r { bottom: 260rpx; right: 64rpx; width: 88rpx; height: 140rpx; }
.s-trunk {
  position: absolute;
  bottom: 0; left: 50%;
  transform: translateX(-50%);
  width: 14rpx; height: 56rpx;
  border-radius: 6rpx;
  background: #A07038;
}
.s-crown {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  border-radius: 50%;
}
.s-crown-b { bottom: 40rpx; width: 76rpx; height: 76rpx; background: #6EA845; }
.s-crown-t { bottom: 84rpx; width: 54rpx; height: 54rpx; background: #82BD58; }

/* ── 小房子 ── */
.s-house {
  position: absolute;
  bottom: 260rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
}
.s-roof {
  position: relative;
  width: 0; height: 0;
  border-left: 56rpx solid transparent;
  border-right: 56rpx solid transparent;
  border-bottom: 54rpx solid #CC5858;
  margin: 0 auto;
}
.s-chimney {
  position: absolute;
  top: -22rpx; right: 18rpx;
  width: 14rpx; height: 26rpx;
  background: #B84848;
  border-radius: 3rpx 3rpx 0 0;
}
.s-wall {
  width: 90rpx; height: 62rpx;
  background: #F5F0E0;
  border-radius: 0;
  margin: 0 auto;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.s-door {
  width: 24rpx; height: 36rpx;
  background: #D89050;
  border-radius: 12rpx 12rpx 0 0;
}

/* ── 文字区：固定在太阳下方、山丘上方的区域居中 ── */
.s-center {
  position: absolute;
  top: 480rpx; left: 0; right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  z-index: 2;
}
.s-title {
  font-size: 100rpx;
  font-weight: 900;
  color: #2A1F10;
  letter-spacing: 16rpx;
  text-align: center;
}
.s-sub-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
}
.s-sub-line {
  width: 44rpx; height: 2rpx;
  background: #B0A080;
  opacity: 0.45;
}
.s-sub {
  font-size: 30rpx;
  color: #5A4A36;
  letter-spacing: 2rpx;
  text-align: center;
}
.s-en {
  font-size: 20rpx;
  color: #A89F92;
  letter-spacing: 6rpx;
  margin-top: 12rpx;
  text-align: center;
}

/* ── 按钮区：固定在底部，树和房子在按钮上方 ── */
.s-btn-wrap {
  position: absolute;
  bottom: 80rpx;
  left: 56rpx; right: 56rpx;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}
.s-btn {
  width: 100%;
  background: #F5C842;
  border-radius: 60rpx;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(245,200,66,0.5);
}
.s-btn-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #2A1F10;
  letter-spacing: 4rpx;
}
.s-days-text {
  font-size: 22rpx;
  color: #9A8F7E;
  letter-spacing: 1rpx;
}

/* ── 主容器 ── */
.container {
  width: 100%;
  min-height: 100vh;
  padding: 36rpx 24rpx 200rpx;
  box-sizing: border-box;
  background: #FAF8F4;
  font-family: 'Noto Sans SC', sans-serif;
}

/* ── Header ── */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
  padding: 0 4rpx;
}
.header-left { display: flex; flex-direction: column; gap: 12rpx; }
.header-date {
  font-size: 26rpx;
  color: #B0A795;
  letter-spacing: 2rpx;
  font-weight: 500;
}
.header-greeting {
  font-size: 54rpx;
  font-weight: 900;
  color: #2A1F10;
  line-height: 1.15;
}
.header-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #F3D9A0;
  border: 4rpx solid #fff;
  box-shadow: 0 6rpx 20rpx rgba(42,31,16,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

/* ── 养生签 ── */
.wellness-card {
  background: #F5C842;
  border-radius: 48rpx;
  padding: 44rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 20rpx 48rpx rgba(245,200,66,0.35);
  margin-bottom: 44rpx;
}
.wellness-circle-bg {
  position: absolute;
  top: -52rpx; right: -40rpx;
  width: 192rpx; height: 192rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.28);
}
.wellness-circle-sm {
  position: absolute;
  top: 16rpx; right: 32rpx;
  width: 84rpx; height: 84rpx;
  border-radius: 50%;
  background: #FBE7B0;
}
.wellness-chip {
  display: inline-flex;
  background: rgba(42,31,16,0.12);
  border-radius: 40rpx;
  padding: 10rpx 24rpx;
  margin-bottom: 28rpx;
}
.wellness-chip-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #5A4516;
  letter-spacing: 2rpx;
}
.wellness-wisdom {
  font-size: 38rpx;
  font-weight: 700;
  color: #2A1F10;
  line-height: 1.6;
  display: block;
}
.wellness-tip-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 32rpx;
}
.wellness-tip-icon {
  width: 44rpx; height: 44rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}
.wellness-tip-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #5A4516;
}

/* ── 分区标题 ── */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding: 0 4rpx;
}
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2A1F10;
}
.section-more {
  font-size: 26rpx;
  color: #B0A795;
  font-weight: 600;
}

/* ── 快捷入口 ── */
.quick-entry {
  background: #fff;
  border-radius: 44rpx;
  border: 3rpx dashed #E6DECE;
  padding: 32rpx 36rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(42,31,16,0.06);
}
.quick-icon-box {
  width: 84rpx; height: 84rpx;
  border-radius: 28rpx;
  background: #FBEFC9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}
.quick-text {
  font-size: 30rpx;
  color: #A89F92;
  font-weight: 400;
}

/* ── 表单 ── */
.form-card {
  background: #fff;
  border-radius: 44rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(42,31,16,0.06);
  margin-bottom: 28rpx;
}
.mood-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
  flex-wrap: wrap;
}
.mood-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #F7F4EF;
  border: 1px solid rgba(42,31,16,0.08);
}
.mood-item.selected {
  background: #F5C842;
  border-color: #F5C842;
}
.mood-emoji { font-size: 34rpx; }
.mood-label { font-size: 22rpx; color: #5A4A38; }
.mood-item.selected .mood-label { color: #2A1F10; font-weight: 700; }

.textarea {
  width: 100%;
  min-height: 180rpx;
  font-size: 30rpx;
  color: #2A1F10;
  line-height: 1.85;
  background: #FBF5EA;
  border-radius: 26rpx;
  padding: 26rpx;
  box-sizing: border-box;
}
.placeholder { color: #C8B8AF; }
.char-count {
  text-align: right;
  font-size: 18rpx;
  color: #B7A998;
  margin: 10rpx 0 18rpx;
}

.date-row { display: flex; gap: 14rpx; margin-bottom: 20rpx; }
.date-picker-btn {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 18rpx;
  background: #F8F4EA;
  border-radius: 22rpx;
}
.date-icon { font-size: 24rpx; }
.date-text { font-size: 22rpx; color: #2A1F10; }

.photo-picker {
  width: 100%;
  min-height: 140rpx;
  border-radius: 28rpx;
  border: 1px dashed #E6DECE;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}
.photo-placeholder { display: flex; align-items: center; justify-content: center; }
.photo-hint { font-size: 26rpx; color: #9E8B7E; }
.photo-preview { width: 100%; height: 240rpx; border-radius: 28rpx; }

.submit-btn {
  width: 100%;
  background: #F5C842;
  border-radius: 56rpx;
  padding: 28rpx 0;
  text-align: center;
  font-size: 30rpx;
  color: #2A1F10;
  font-weight: 700;
  box-shadow: 0 12rpx 32rpx rgba(245,200,66,0.4);
}
.submit-btn.disabled { background: rgba(245,200,66,0.45); box-shadow: none; }

/* ── 空/加载 ── */
.loading, .empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  gap: 18rpx;
}
.loading-text, .empty-text { font-size: 26rpx; color: #9E8B7E; }
.empty-icon { font-size: 68rpx; }

/* ── 日记卡片 ── */
.record-card {
  background: #fff;
  border-radius: 44rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(42,31,16,0.06);
}
.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.record-mood-chip {
  display: inline-flex;
  align-items: center;
  border-radius: 32rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.record-mood-chip.happy  { background: #EAF1DC; color: #6E8B49; }
.record-mood-chip.tired  { background: #FBE6D9; color: #C77A4F; }
.record-mood-chip.normal { background: #EDE8DF; color: #7A6D5F; }
.record-mood-chip        { background: #EDE8DF; color: #7A6D5F; }
.record-time {
  font-size: 24rpx;
  color: #B0A795;
  font-weight: 500;
}
.img-ratio-wrap {
  width: 100%;
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  margin-bottom: 22rpx;
}
.img-4-3 { padding-bottom: 75%; }
.img-ratio-img {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
}
.record-text {
  display: block;
  font-size: 30rpx;
  color: #3D3324;
  line-height: 1.8;
  font-weight: 300;
  white-space: pre-wrap;
  margin-bottom: 20rpx;
}
.record-actions {
  display: flex;
  gap: 14rpx;
  justify-content: flex-end;
}
.record-actions .action-edit,
.record-actions .action-delete {
  padding: 14rpx 24rpx;
  border-radius: 22rpx;
  background: #F7F4EF;
  color: #2A1F10;
  font-size: 22rpx;
}

.edit-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}
.action-cancel {
  flex: 1;
  border-radius: 28rpx;
  padding: 22rpx 0;
  font-size: 26rpx;
  text-align: center;
  background: #F3EFE8;
  color: #7A6D5F;
}
.action-save {
  flex: 1;
  border-radius: 28rpx;
  padding: 22rpx 0;
  font-size: 26rpx;
  text-align: center;
  background: #F5C842;
  color: #2A1F10;
  font-weight: 700;
}

.edit-photo-wrap { position: relative; }
.edit-photo-remove {
  position: absolute;
  top: 12rpx; right: 12rpx;
  width: 44rpx; height: 44rpx;
  border-radius: 22rpx;
  background: rgba(42,31,16,0.8);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

/* ── 回应弹层 ── */
.response-overlay {
  position: fixed;
  inset: 0;
  background: rgba(42,31,16,0.4);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
}
.response-overlay.show { opacity: 1; visibility: visible; }
.response-card {
  background: #fff;
  border-radius: 44rpx;
  padding: 48rpx 36rpx;
  max-width: 88%;
  box-shadow: 0 8rpx 32rpx rgba(42,31,16,0.1);
}
.response-text {
  font-size: 30rpx;
  color: #2A1F10;
  line-height: 1.8;
  text-align: center;
}
