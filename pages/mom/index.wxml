<!-- 开屏动画 -->
<view wx:if="{{showSplash}}" class="splash {{splashFading ? 'splash-out' : 'splash-in'}}">
  <view class="splash-content">
    <text class="splash-emoji">💕</text>
    <text class="splash-title">我在这里</text>
    <text class="splash-sub">今天也是值得记录的一天呀！</text>
  </view>
</view>

<view class="container">

  <!-- 上：居中区 -->
  <view class="hero">

    <!-- 今日养生签 -->
    <view class="wellness-card" bindtap="onWellnessTap">
      <text class="wellness-icon">{{wellnessSign.icon}}</text>
      <text class="wellness-tag">今日养生签</text>
      <text class="wellness-wisdom {{wellnessOpened ? '' : 'sealed'}}">
        {{wellnessOpened ? wellnessSign.wisdom : '轻触解锁今日签'}}
      </text>
      <text class="wellness-care" wx:if="{{wellnessOpened}}">— {{wellnessSign.care}}</text>
    </view>

    <!-- 问候 -->
    <text class="greeting-text">{{greeting}}</text>

  </view>

  <!-- 分隔 -->
  <view class="section-sep">
    <view class="sep-line"></view>
    <text class="sep-label">今日记录</text>
    <view class="sep-line"></view>
  </view>

  <!-- 下：日记区 -->
  <view class="diary">

    <!-- 记一下入口 -->
    <view class="add-btn {{showForm ? 'cancel' : ''}}" bindtap="toggleForm">
      <text>{{showForm ? '× 取消' : '+ 记一下'}}</text>
    </view>

    <!-- 新增表单 -->
    <view class="form-card" wx:if="{{showForm}}">
      <view class="mood-row">
        <view
          wx:for="{{moods}}"
          wx:key="label"
          class="mood-item {{selectedMood === index ? 'selected' : ''}}"
          data-index="{{index}}"
          bindtap="selectMood"
        >
          <text class="mood-emoji">{{item.emoji}}</text>
          <text class="mood-label">{{item.label}}</text>
        </view>
      </view>
      <textarea
        class="textarea"
        placeholder="今天想记点什么…"
        placeholder-class="placeholder"
        value="{{inputText}}"
        bindinput="onTextInput"
        maxlength="300"
        auto-height
      />
      <view class="char-count">{{inputText.length}}/300</view>
      <!-- 时间选择 -->
      <view class="date-row">
        <picker mode="date" value="{{selectedDate}}" end="{{today}}" bindchange="onDateChange">
          <view class="date-picker-btn">
            <text class="date-icon">📅</text>
            <text class="date-text">{{selectedDate === today ? '今天' : selectedDate}}</text>
          </view>
        </picker>
        <picker mode="time" value="{{selectedTime}}" bindchange="onTimeChange">
          <view class="date-picker-btn">
            <text class="date-icon">🕐</text>
            <text class="date-text">{{selectedTime}}</text>
          </view>
        </picker>
      </view>
      <!-- 可选照片 -->
      <view class="photo-picker" bindtap="choosePhoto">
        <view wx:if="{{!photoPath}}" class="photo-placeholder">
          <text class="photo-icon">📷</text>
          <text class="photo-hint">加一张照片（可选）</text>
        </view>
        <image wx:else class="photo-preview" src="{{photoPath}}" mode="aspectFill" />
      </view>
      <view class="submit-btn {{(!inputText || submitting) ? 'disabled' : ''}}" bindtap="onSubmit">
        <text>{{submitting ? '存中…' : '存下来 💕'}}</text>
      </view>
    </view>

    <!-- 记录列表 -->
    <view class="loading" wx:if="{{loading}}">
      <text class="loading-text">加载中…</text>
    </view>
    <view class="empty" wx:elif="{{!loading && records.length === 0 && !showForm}}">
      <text class="empty-icon">🌸</text>
      <text class="empty-text">还没有记录，来记一下今天吧</text>
    </view>
    <view wx:elif="{{!showForm}}">
      <view wx:for="{{records}}" wx:key="id" class="record-card">

        <view wx:if="{{editingId !== item.id}}">
          <view class="record-top">
            <text class="record-time">{{item.timeStr}}</text>
            <text class="record-mood" wx:if="{{item.mood}}">{{item.mood}}</text>
          </view>
          <image wx:if="{{item.image}}" class="record-image" src="{{item.image}}" mode="aspectFill" />
          <text class="record-text">{{item.text}}</text>
          <view class="record-actions" wx:if="{{userRole === 'mom'}}">
            <view class="action-edit" data-id="{{item.id}}" bindtap="startEdit">
              <text>✏️ 编辑</text>
            </view>
            <view class="action-delete" data-id="{{item.id}}" bindtap="deleteRecord">
              <text>🗑️ 删除</text>
            </view>
          </view>
        </view>

        <view wx:else>
          <view class="mood-row">
            <view
              wx:for="{{moods}}"
              wx:for-item="mood"
              wx:key="label"
              class="mood-item {{editingMood === index ? 'selected' : ''}}"
              data-index="{{index}}"
              bindtap="selectEditMood"
            >
              <text class="mood-emoji">{{mood.emoji}}</text>
              <text class="mood-label">{{mood.label}}</text>
            </view>
          </view>
          <textarea
            class="textarea"
            value="{{editingText}}"
            bindinput="onEditInput"
            maxlength="300"
            auto-height
          />
          <!-- 照片编辑 -->
          <view class="photo-picker" style="margin-top:20rpx" bindtap="editChoosePhoto">
            <view wx:if="{{!editingPhoto}}" class="photo-placeholder">
              <text class="photo-icon">📷</text>
              <text class="photo-hint">加一张照片（可选）</text>
            </view>
            <view wx:else class="edit-photo-wrap">
              <image class="photo-preview" src="{{editingPhoto}}" mode="aspectFill" />
              <view class="edit-photo-remove" catchtap="editRemovePhoto">×</view>
            </view>
          </view>
          <view class="edit-actions">
            <view class="action-cancel" bindtap="cancelEdit"><text>取消</text></view>
            <view class="action-save"   bindtap="saveEdit"  ><text>保存</text></view>
          </view>
        </view>

      </view>
    </view>

  </view>

  <!-- 温暖回应浮层 -->
  <view class="response-overlay {{showResponse ? 'show' : ''}}" bindtap="dismissResponse">
    <view class="response-card">
      <text class="response-text">{{warmResponse}}</text>
    </view>
  </view>

</view>
