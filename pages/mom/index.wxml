<!-- 开屏动画 -->
<view wx:if="{{showSplash}}" class="splash {{splashFading ? 'splash-out' : 'splash-in'}}">
  <view class="splash-bg">

    <!-- 太阳 -->
    <view class="s-sun">
      <view class="s-sun-face">
        <view class="s-eye s-eye-l"></view>
        <view class="s-eye s-eye-r"></view>
        <view class="s-smile"></view>
      </view>
      <!-- 光芒 -->
      <view class="s-ray s-ray-1"></view>
      <view class="s-ray s-ray-2"></view>
      <view class="s-ray s-ray-3"></view>
      <view class="s-ray s-ray-4"></view>
      <view class="s-ray s-ray-5"></view>
      <view class="s-ray s-ray-6"></view>
      <view class="s-ray s-ray-7"></view>
      <view class="s-ray s-ray-8"></view>
    </view>

    <!-- 云朵 -->
    <view class="s-cloud s-cloud-1">
      <view class="s-cloud-body"></view>
      <view class="s-cloud-puff s-puff-1"></view>
      <view class="s-cloud-puff s-puff-2"></view>
    </view>
    <view class="s-cloud s-cloud-2">
      <view class="s-cloud-body"></view>
      <view class="s-cloud-puff s-puff-1"></view>
      <view class="s-cloud-puff s-puff-2"></view>
    </view>

    <!-- 山丘层 -->
    <view class="s-hills">
      <view class="s-hill s-hill-far-l"></view>
      <view class="s-hill s-hill-far-r"></view>
      <view class="s-hill s-hill-mid-l"></view>
      <view class="s-hill s-hill-mid-r"></view>
      <view class="s-hill s-hill-front"></view>
      <view class="s-hill s-hill-shadow-l"></view>
      <view class="s-hill s-hill-shadow-r"></view>

      <!-- 左树 -->
      <view class="s-tree s-tree-l">
        <view class="s-trunk"></view>
        <view class="s-crown s-crown-b"></view>
        <view class="s-crown s-crown-t"></view>
      </view>
      <!-- 右树 -->
      <view class="s-tree s-tree-r">
        <view class="s-trunk"></view>
        <view class="s-crown s-crown-b"></view>
        <view class="s-crown s-crown-t"></view>
      </view>
      <!-- 小房子 -->
      <view class="s-house">
        <view class="s-roof"></view>
        <view class="s-chimney"></view>
        <view class="s-wall">
          <view class="s-door"></view>
        </view>
      </view>
    </view>

  </view>

  <!-- 文字区 -->
  <view class="s-center">
    <text class="s-title">我在这里</text>
    <view class="s-sub-row">
      <view class="s-sub-line"></view>
      <text class="s-sub">新的一天，从记录开始</text>
      <view class="s-sub-line"></view>
    </view>
    <text class="s-en">I'M HERE WITH YOU</text>
  </view>

  <!-- 按钮 -->
  <view class="s-btn-wrap" bindtap="onSplashTap">
    <view class="s-btn">
      <text class="s-btn-text">开始使用 →</text>
    </view>
    <text wx:if="{{daysTogether}}" class="s-days-text">已记录 {{daysTogether}} 天</text>
  </view>
</view>

<!-- 主内容 -->
<view class="container">
  <!-- 顶部 header -->
  <view class="header">
    <view class="header-left">
      <text class="header-date">{{headerDate}}</text>
      <text class="header-greeting">{{greeting}}</text>
    </view>
    <view class="header-avatar" bindtap="onWellnessTap">🌷</view>
  </view>

  <!-- 养生签卡片 -->
  <view class="wellness-card" bindtap="onWellnessTap">
    <view class="wellness-circle-bg"></view>
    <view class="wellness-circle-sm"></view>
    <view class="wellness-chip">
      <text class="wellness-chip-text">今日养生签 · 第 {{wellnessSign.no || 128}} 签</text>
    </view>
    <text class="wellness-wisdom">{{wellnessOpened ? wellnessSign.wisdom : '早起喝杯温水，\n给肠胃一个温柔的早安。'}}</text>
    <view class="wellness-tip-row">
      <view class="wellness-tip-icon">🔓</view>
      <text class="wellness-tip-text">轻触卡片，解锁今天的小提醒</text>
    </view>
  </view>

  <!-- 分区标题 -->
  <view class="section-header">
    <text class="section-title">日常记录</text>
    <text class="section-more">全部 ›</text>
  </view>

  <!-- 快捷记录入口（仅妈妈） -->
  <view wx:if="{{userRole === 'mom'}}" class="quick-entry" bindtap="toggleForm">
    <view class="quick-icon-box">
      <text class="quick-icon">✏️</text>
    </view>
    <text class="quick-text">{{showForm ? '× 取消编辑' : '记录今天'}}</text>
  </view>

  <!-- 记录表单（仅妈妈） -->
  <view class="form-card" wx:if="{{userRole === 'mom' && showForm}}">
    <view class="mood-row">
      <view
        wx:for="{{moods}}"
        wx:key="label"
        class="mood-item {{selectedMood === index ? 'selected' : ''}}"
        data-index="{{index}}"
        bindtap="selectMood"
      >
        <text class="mood-emoji">{{item.emoji}}</text>
        <text class="mood-label">{{item.label}}</text>
      </view>
    </view>
    <textarea
      class="textarea"
      placeholder="今日记录"
      placeholder-class="placeholder"
      value="{{inputText}}"
      bindinput="onTextInput"
      maxlength="300"
      auto-height
    />
    <text class="char-count">{{inputText.length}}/300</text>
    <view class="date-row">
      <picker mode="date" value="{{selectedDate}}" end="{{today}}" bindchange="onDateChange">
        <view class="date-picker-btn">
          <text class="date-icon">📅</text>
          <text class="date-text">{{selectedDate === today ? '今天' : selectedDate}}</text>
        </view>
      </picker>
      <picker mode="time" value="{{selectedTime}}" bindchange="onTimeChange">
        <view class="date-picker-btn">
          <text class="date-icon">🕐</text>
          <text class="date-text">{{selectedTime}}</text>
        </view>
      </picker>
    </view>
    <view class="photo-picker" bindtap="choosePhoto">
      <view wx:if="{{!photoPath}}" class="photo-placeholder">
        <text class="photo-hint">📷 加一张照片（可选）</text>
      </view>
      <image wx:else class="photo-preview" src="{{photoPath}}" mode="aspectFill" />
    </view>
    <view class="submit-btn {{(!inputText || submitting) ? 'disabled' : ''}}" bindtap="onSubmit">
      <text>{{submitting ? '存中…' : '存下来 💕'}}</text>
    </view>
  </view>

  <!-- 加载 / 空状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text class="loading-text">加载中…</text>
  </view>
  <view class="empty" wx:elif="{{!loading && records.length === 0 && !showForm}}">
    <text class="empty-icon">🌸</text>
    <text class="empty-text">今天还没有记录</text>
  </view>

  <!-- 日记列表 -->
  <view wx:elif="{{!showForm}}">
    <view wx:for="{{records}}" wx:key="id" class="record-card">
      <view wx:if="{{editingId !== item.id}}">
        <view class="record-top">
          <view class="record-mood-chip {{item.moodKey}}">
            <text>{{item.mood || '📝 记录'}}</text>
          </view>
          <text class="record-time">{{item.timeStr}}</text>
        </view>
        <view wx:if="{{item.image}}" class="img-ratio-wrap img-4-3">
          <image class="img-ratio-img" src="{{item.image}}" mode="aspectFill" />
        </view>
        <text class="record-text">{{item.text}}</text>
        <view class="record-actions" wx:if="{{userRole === 'mom'}}">
          <view class="action-edit" data-id="{{item.id}}" bindtap="startEdit"><text>✏️ 编辑</text></view>
          <view class="action-delete" data-id="{{item.id}}" bindtap="deleteRecord"><text>🗑️ 删除</text></view>
        </view>
      </view>
      <view wx:else>
        <view class="mood-row">
          <view
            wx:for="{{moods}}"
            wx:for-item="mood"
            wx:key="label"
            class="mood-item {{editingMood === index ? 'selected' : ''}}"
            data-index="{{index}}"
            bindtap="selectEditMood"
          >
            <text class="mood-emoji">{{mood.emoji}}</text>
            <text class="mood-label">{{mood.label}}</text>
          </view>
        </view>
        <textarea
          class="textarea"
          value="{{editingText}}"
          bindinput="onEditInput"
          maxlength="300"
          auto-height
        />
        <view class="photo-picker" style="margin-top:20rpx" bindtap="editChoosePhoto">
          <view wx:if="{{!editingPhoto}}" class="photo-placeholder">
            <text class="photo-hint">📷 加一张照片（可选）</text>
          </view>
          <view wx:else class="edit-photo-wrap">
            <image class="photo-preview" src="{{editingPhoto}}" mode="aspectFill" />
            <view class="edit-photo-remove" catchtap="editRemovePhoto">×</view>
          </view>
        </view>
        <view class="edit-actions">
          <view class="action-cancel" bindtap="cancelEdit"><text>取消</text></view>
          <view class="action-save" bindtap="saveEdit"><text>保存</text></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 回应弹层 -->
  <view class="response-overlay {{showResponse ? 'show' : ''}}" bindtap="dismissResponse">
    <view class="response-card">
      <text class="response-text">{{warmResponse}}</text>
    </view>
  </view>
</view>
