.container {
  padding: 48rpx 40rpx 80rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.title-input {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  color: #3D2B1F;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.textarea {
  width: 100%;
  min-height: 300rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #3D2B1F;
  line-height: 1.8;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.placeholder { color: #C8B8AF; }

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #C8B8AF;
  margin-top: 12rpx;
  margin-bottom: 40rpx;
}

.submit-btn {
  background: #F4A261;
  border-radius: 20rpx;
  padding: 32rpx 0;
  text-align: center;
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(244,162,97,0.4);
}
.submit-btn.disabled { background: #E0D0C8; box-shadow: none; }

.success {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  gap: 24rpx;
}

.success-icon { font-size: 96rpx; }

.success-text {
  font-size: 32rpx;
  color: #3D2B1F;
  line-height: 1.7;
  text-align: center;
}

.back-btn {
  margin-top: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 60rpx;
  font-size: 28rpx;
  color: #F4A261;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
