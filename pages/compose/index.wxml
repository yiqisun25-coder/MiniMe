<view class="container">

  <view wx:if="{{!submitted}}">
    <input
      class="title-input"
      placeholder="标题"
      placeholder-class="placeholder"
      value="{{title}}"
      bindinput="onTitleInput"
      maxlength="30"
    />

    <textarea
      class="textarea"
      placeholder="正文…"
      placeholder-class="placeholder"
      value="{{content}}"
      bindinput="onContentInput"
      maxlength="1000"
      auto-height
    />
    <view class="char-count">{{content.length}}/1000</view>

    <view
      class="submit-btn {{(!title || !content || submitting) ? 'disabled' : ''}}"
      bindtap="onSubmit"
    >
      <text>{{submitting ? '发送中…' : '保存'}}</text>
    </view>
  </view>

  <view class="success" wx:else>
    <text class="success-icon">📮</text>
    <text class="success-text">已保存</text>
    <view class="back-btn" bindtap="onBack">
      <text>返回</text>
    </view>
  </view>

</view>
