<view class="container">

  <view class="greeting-card">
    <text class="greeting-text">记录今天</text>
    <text class="greeting-sub">随手写下此刻</text>
  </view>

  <view wx:if="{{!submitted}}">
    <textarea
      class="textarea"
      placeholder="今日记录"
      placeholder-class="placeholder"
      value="{{inputText}}"
      bindinput="onInput"
      maxlength="500"
      auto-height
    />
    <view class="char-count">{{inputText.length}}/500</view>
    <view
      class="submit-btn {{(!inputText || submitting) ? 'disabled' : ''}}"
      bindtap="onSubmit"
    >
      <text>{{submitting ? '发送中…' : '保存'}}</text>
    </view>
  </view>

  <view class="success" wx:else>
    <text class="success-icon">💌</text>
    <text class="success-text">已保存</text>
    <view class="again-btn" bindtap="onReset">
      <text>再记一条</text>
    </view>
  </view>

</view>
