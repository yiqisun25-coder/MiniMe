.container {
  padding: 60rpx 48rpx 100rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.greeting-card {
  background: #FFFCF7;
  border-radius: 20rpx;
  padding: 44rpx;
  border: 1rpx solid rgba(42, 31, 16, 0.1);
  margin-bottom: 32rpx;
}

.greeting-text {
  display: block;
  font-size: 32rpx;
  color: #2A1F10;
  font-weight: 600;
  line-height: 1.65;
  margin-bottom: 10rpx;
}

.greeting-sub {
  display: block;
  font-size: 26rpx;
  color: #8A7A68;
}

.textarea {
  width: 100%;
  min-height: 220rpx;
  background: #FFFCF7;
  border-radius: 16rpx;
  padding: 32rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #2A1F10;
  line-height: 1.8;
  border: 1rpx solid rgba(42, 31, 16, 0.1);
}

.placeholder { color: #B8A898; }

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #B8A898;
  margin-top: 10rpx;
  margin-bottom: 36rpx;
  letter-spacing: 0.3rpx;
}

.submit-btn {
  background: #2D3926;
  border-radius: 16rpx;
  padding: 36rpx 0;
  text-align: center;
  font-size: 30rpx;
  color: #F3E8D4;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.submit-btn.disabled {
  background: rgba(42, 31, 16, 0.12);
  color: #B8A898;
}

.success {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  gap: 24rpx;
}

.success-icon { font-size: 88rpx; }

.success-text {
  font-size: 30rpx;
  color: #2A1F10;
  line-height: 1.9;
  text-align: center;
}

.again-btn {
  margin-top: 24rpx;
  background: transparent;
  border-radius: 48rpx;
  padding: 24rpx 64rpx;
  font-size: 26rpx;
  color: #5A4A38;
  border: 1rpx solid rgba(42, 31, 16, 0.2);
}
