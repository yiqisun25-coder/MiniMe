<view class="page-container">
  <!-- 顶部日期 -->
  <view class="top-meta">
    <text class="top-date">{{heroDate}}</text>
    <text class="page-title">我的</text>
  </view>

  <!-- 头像区域 -->
  <view class="avatar-section">
    <view class="avatar-halo"></view>
    <view class="avatar-ring" bindtap="onAvatarTap">
      <image class="hero-avatar" src="{{avatarSrc}}" mode="aspectFill" />
    </view>
    <text wx:if="{{adminHint}}" class="admin-hint">{{adminHint}}</text>
    <!-- 侧边图标 -->
    <view class="side-icon side-icon-left"><text>☀️</text></view>
    <view class="side-icon side-icon-right"><text>🌙</text></view>
    <!-- 状态气泡 -->
    <view class="status-bubble {{bubbleVisible ? 'bubble-show' : ''}}">
      <text class="status-text">{{bubbleVisible ? currentResponse : '「美好的一天开始啦 🌸」'}}</text>
    </view>
  </view>

  <!-- 动作网格：女儿端 = 功能入口；妈妈端场景卡片审核期间隐藏（showScenes 开关，代码保留） -->
  <view class="action-section">
    <text class="action-title">快捷入口</text>

    <!-- 女儿端功能网格 -->
    <view wx:if="{{isDaughter}}" class="action-grid">
      <view class="action-card morning" bindtap="goCompose">
        <text class="action-emoji">✏️</text>
        <text class="action-label">长文记录</text>
        <text class="action-sub">记录长文</text>
      </view>
      <view class="action-card night" bindtap="goDaily">
        <text class="action-emoji">📝</text>
        <text class="action-label">记录日常</text>
        <text class="action-sub">记录今天</text>
      </view>
      <view class="action-card miss" bindtap="goMemory">
        <text class="action-emoji">🔒</text>
        <text class="action-label">定时记录</text>
        <text class="action-sub">到期可见</text>
      </view>
      <view class="action-card secret" bindtap="goAdmin">
        <text class="action-emoji">⚙️</text>
        <text class="action-label">设置</text>
        <text class="action-sub">数据管理</text>
      </view>
    </view>

    <!-- 妈妈端场景网格（审核期间 showScenes=false 隐藏，过审后恢复） -->
    <view wx:elif="{{showScenes}}" class="action-grid">
      <view
        wx:for="{{scenes}}"
        wx:key="key"
        class="action-card {{item.key}}"
        data-key="{{item.key}}"
        bindtap="onSceneTap"
      >
        <text class="action-emoji">{{item.emoji}}</text>
        <text class="action-label">{{item.label}}</text>
        <text class="action-sub">{{item.desc}}</text>
      </view>
    </view>

    <!-- 妈妈端审核期间显示：中性快捷入口 -->
    <view wx:else class="action-grid">
      <view class="action-card morning" bindtap="goToMailbox">
        <text class="action-emoji">📂</text>
        <text class="action-label">归档记录</text>
        <text class="action-sub">查看长文</text>
      </view>
      <view class="action-card night" bindtap="goTalk">
        <text class="action-emoji">📝</text>
        <text class="action-label">快捷记录</text>
        <text class="action-sub">随手记一条</text>
      </view>
    </view>
  </view>

  <!-- 归档记录入口（仅妈妈端） -->
  <view wx:if="{{!isDaughter}}" class="letter-entry" bindtap="goToMailbox">
    <view class="letter-entry-left">
      <text class="letter-entry-icon">📂</text>
      <view>
        <text class="letter-entry-title">归档记录</text>
        <text class="letter-entry-sub">查看已同步的长文记录</text>
      </view>
    </view>
    <view class="letter-entry-right">
      <view class="letter-badge" wx:if="{{unreadCount > 0}}">
        <text class="letter-badge-num">{{unreadCount}}</text>
      </view>
      <text class="letter-entry-arrow">›</text>
    </view>
  </view>
</view>
