<view class="container">

  <!-- 头像 — 连点5次进后台 -->
  <view class="avatar-wrap" bindtap="onAvatarTap">
    <image class="avatar" src="{{avatarSrc}}" mode="aspectFill" />
  </view>

  <!-- 时间问候 -->
  <text class="greeting">{{greeting}}</text>

  <!-- 场景卡片回应 -->
  <text class="subtitle {{bubbleVisible ? 'visible' : 'hidden'}}">{{currentResponse}}</text>

  <!-- 场景卡片 2×2 -->
  <view class="scenes">
    <view
      wx:for="{{scenes}}"
      wx:key="key"
      class="scene-card {{activeScene === item.key ? 'active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onSceneTap"
    >
      <view class="scene-img-area">
        <text class="scene-emoji">{{item.emoji}}</text>
      </view>

      <view class="scene-text-area">
        <text class="scene-label">{{item.label}}</text>
        <text class="scene-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

</view>
