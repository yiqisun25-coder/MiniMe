.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 72rpx 32rpx 160rpx;
  box-sizing: border-box;
}

/* ── 头像 ── */
.avatar-wrap {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx solid rgba(42, 31, 16, 0.12);
  box-shadow: 0 4rpx 20rpx rgba(42, 31, 16, 0.1);
}
.avatar { width: 100%; height: 100%; }

/* ── 问候语 ── */
.greeting {
  margin-top: 28rpx;
  font-size: 44rpx;
  color: #2A1F10;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* ── 场景回应文字 ── */
.subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #8A7A68;
  letter-spacing: 0.5rpx;
  text-align: center;
  line-height: 1.7;
  transition: opacity 0.25s ease;
}
.subtitle.visible { opacity: 1; }
.subtitle.hidden  { opacity: 0; }

/* ── 场景卡片网格 ── */
.scenes {
  margin-top: 40rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  width: 100%;
}

.scene-card {
  width: calc(50% - 8rpx);
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(42, 31, 16, 0.07);
  box-shadow: 0 2rpx 10rpx rgba(42, 31, 16, 0.05);
  box-sizing: border-box;
}

.scene-img-area {
  height: 180rpx;
  background: #F5F0E8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scene-card.active .scene-img-area {
  background: #2D3926;
}

.scene-emoji { font-size: 72rpx; }

.scene-text-area {
  padding: 20rpx 24rpx 26rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.scene-label {
  font-size: 28rpx;
  color: #2A1F10;
  font-weight: 600;
}

.scene-desc {
  font-size: 22rpx;
  color: #9E8B7E;
  line-height: 1.5;
}

.scene-card.active .scene-label { color: #2D3926; }
.scene-card.active .scene-desc  { color: #7A8A76; }
