.page-container {
  width: 100%;
  min-height: 100vh;
  padding: 36rpx 24rpx 200rpx;
  box-sizing: border-box;
  background: #FAF8F4;
  font-family: 'Noto Sans SC', sans-serif;
}

/* ── 顶部 ── */
.top-meta {
  text-align: center;
  padding-bottom: 4rpx;
}
.top-date {
  display: block;
  font-size: 24rpx;
  color: #B0A795;
  letter-spacing: 4rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}
.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 900;
  color: #2A1F10;
}

/* ── 头像区域 ── */
.avatar-section {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 560rpx;
  margin: 0 0 8rpx;
}
.avatar-halo {
  position: absolute;
  width: 344rpx;
  height: 344rpx;
  border-radius: 50%;
  background: rgba(245,200,66,0.16);
}
.avatar-ring {
  width: 272rpx;
  height: 272rpx;
  border-radius: 50%;
  background: #F3D9A0;
  border: 8rpx solid #fff;
  box-shadow: 0 24rpx 60rpx rgba(42,31,16,0.14);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 128rpx;
  z-index: 2;
}
.hero-avatar {
  width: 100%;
  height: 100%;
}

.side-icon {
  position: absolute;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(42,31,16,0.08);
  top: 80rpx;
}
.side-icon-left  { left: 60rpx;  background: #FBEFC9; }
.side-icon-right { right: 60rpx; background: #E7EAF3; }

.status-bubble {
  position: absolute;
  bottom: 80rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 22rpx 36rpx;
  box-shadow: 0 12rpx 36rpx rgba(42,31,16,0.08);
  white-space: nowrap;
}
.status-text {
  font-size: 28rpx;
  color: #3D3324;
  font-weight: 500;
}

/* ── 动作网格 ── */
.action-section {
  padding: 0 4rpx;
}
.action-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #2A1F10;
  margin-bottom: 24rpx;
}
.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 28rpx;
}
.action-card {
  border-radius: 40rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 28rpx rgba(42,31,16,0.06);
}
.action-card.morning { background: #FBEFC9; }
.action-card.night   { background: #E7EAF3; }
.action-card.miss    { background: #FBE0E4; }
.action-card.secret  { background: #EAF1DC; }

.action-emoji { display: block; font-size: 52rpx; margin-bottom: 16rpx; }
.action-label {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #2A1F10;
  margin-bottom: 6rpx;
}
.action-sub {
  display: block;
  font-size: 24rpx;
  color: #9A8F7C;
  font-weight: 300;
}

/* ── 收信箱 ── */
.letter-entry {
  width: 100%;
  background: #fff;
  border-radius: 44rpx;
  box-shadow: 0 8rpx 32rpx rgba(42,31,16,0.06);
  padding: 32rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  box-sizing: border-box;
}
.letter-entry-left {
  display: flex;
  align-items: center;
  gap: 22rpx;
  flex: 1;
  min-width: 0;
}
.letter-entry-icon { font-size: 48rpx; }
.letter-entry-title {
  display: block;
  font-size: 30rpx;
  color: #2A1F10;
  font-weight: 700;
}
.letter-entry-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9E8B7E;
  line-height: 1.5;
}
.letter-entry-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.letter-badge {
  min-width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #2A1F10;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
}
.letter-badge-num { font-size: 22rpx; color: #fff; font-weight: 700; }
.letter-entry-arrow { font-size: 44rpx; color: #2A1F10; }
