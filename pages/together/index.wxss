.container {
  padding: 24rpx 40rpx 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 视图切换 */
.view-toggle {
  display: flex;
  background: rgba(42,31,16,0.06);
  border-radius: 20rpx;
  padding: 6rpx;
  margin-bottom: 36rpx;
}
.toggle-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #9E8B7E;
  transition: all 0.2s;
}
.toggle-btn.active {
  background: #fff;
  color: #2A1F10;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(42,31,16,0.1);
}

/* 相册墙 */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 0 40rpx;
  justify-content: space-between;
}
.polaroid {
  width: 48%;
  margin-bottom: 28rpx;
  background: #fff;
  padding: 16rpx 16rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(42,31,16,0.12);
  border-radius: 4rpx;
  box-sizing: border-box;
  transform-origin: center center;
  overflow: visible;
}
.polaroid-img {
  width: 100%;
  height: 260rpx;
  display: block;
}
.polaroid-caption {
  padding-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.polaroid-text {
  font-size: 22rpx;
  color: #2A1F10;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.polaroid-date {
  font-size: 20rpx;
  color: #C8B8AF;
}

.loading, .empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  gap: 24rpx;
}
.loading-text, .empty-text { font-size: 28rpx; color: #9E8B7E; }
.empty-icon { font-size: 80rpx; }

/* 公共卡片 */
.card {
  border-radius: 24rpx;
  padding: 32rpx 36rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(42,31,16,0.08);
}

.card-tag {
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  letter-spacing: 0.5rpx;
}

.card-text {
  display: block;
  font-size: 30rpx;
  color: #2A1F10;
  line-height: 1.8;
  white-space: pre-wrap;
  margin-bottom: 16rpx;
}

.card-title {
  display: block;
  font-size: 30rpx;
  color: #2A1F10;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-time { font-size: 22rpx; color: #C8B8AF; }
.card-mood { font-size: 22rpx; color: #9E8B7E; }

.card-image {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

/* 妈妈的 — 暖粉 */
.card-mom {
  background: rgba(255, 240, 235, 0.75);
  border-color: rgba(196, 112, 106, 0.15);
}
.card-mom .card-tag { color: #C4706A; }

/* 我的日常 — 暖绿 */
.card-daily {
  background: rgba(240, 248, 238, 0.75);
  border-color: rgba(45, 57, 38, 0.12);
}
.card-daily .card-tag { color: #2D3926; }

/* 解锁记忆 — 暖金 */
.card-memory {
  background: rgba(255, 251, 235, 0.85);
  border-color: rgba(180, 140, 60, 0.18);
}
.card-memory .card-tag { color: #A07830; }

/* 锁住的记忆 */
.card-locked {
  background: rgba(240, 238, 235, 0.5);
  border-color: rgba(42,31,16,0.06);
}
.card-locked .card-tag { color: #C8B8AF; }
.locked-date { font-size: 26rpx; color: #C8B8AF; }
