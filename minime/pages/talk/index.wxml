<view class="container">

  <view class="greeting-card">
    <text class="greeting-text">妈妈，今天有什么想跟我说的？</text>
    <text class="greeting-sub">开心的、不开心的，都可以 💕</text>
  </view>

  <view wx:if="{{!submitted}}">
    <textarea
      class="textarea"
      placeholder="跟我说说…"
      placeholder-class="placeholder"
      value="{{inputText}}"
      bindinput="onInput"
      maxlength="500"
      auto-height
    />
    <view class="char-count">{{inputText.length}}/500</view>
    <view
      class="submit-btn {{(!inputText || submitting) ? 'disabled' : ''}}"
      bindtap="onSubmit"
    >
      <text>{{submitting ? '发送中…' : '告诉我 💌'}}</text>
    </view>
  </view>

  <view class="success" wx:else>
    <text class="success-icon">💌</text>
    <text class="success-text">我收到啦，我都看着呢 ❤️</text>
    <view class="again-btn" bindtap="onReset">
      <text>再说一条</text>
    </view>
  </view>

</view>
