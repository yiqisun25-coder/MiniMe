.container { padding: 48rpx 40rpx 80rpx; min-height: 100vh; box-sizing: border-box; }

.hint { display: block; font-size: 26rpx; color: #9E8B7E; margin-bottom: 28rpx; }

.textarea {
  width: 100%; min-height: 240rpx;
  background: rgba(255,252,247,0.85);
  border-radius: 20rpx; padding: 32rpx;
  box-sizing: border-box; font-size: 30rpx;
  color: #2A1F10; line-height: 1.75;
  border: 1rpx solid rgba(42,31,16,0.1);
}
.placeholder { color: #C8B8AF; }
.char-count { text-align: right; font-size: 22rpx; color: #C8B8AF; margin: 10rpx 0 20rpx; }

.date-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
}
.date-picker {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(255,252,247,0.85);
  border: 1rpx solid rgba(42,31,16,0.1);
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
}
.date-icon { font-size: 28rpx; }
.date-text { font-size: 26rpx; color: #2A1F10; }

.photo-picker {
  display: flex; align-items: center; gap: 16rpx;
  padding: 28rpx 32rpx;
  background: rgba(255,252,247,0.85);
  border: 1rpx dashed rgba(42,31,16,0.15);
  border-radius: 16rpx;
  margin-bottom: 28rpx;
}
.photo-icon { font-size: 36rpx; }
.photo-hint { font-size: 26rpx; color: #C8B8AF; }

.photo-preview-wrap {
  position: relative;
  margin-bottom: 28rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.photo-preview { width: 100%; height: 360rpx; display: block; }
.photo-remove {
  position: absolute; top: 16rpx; right: 16rpx;
  width: 52rpx; height: 52rpx;
  background: rgba(0,0,0,0.45);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; color: #fff; line-height: 1;
}

.submit-btn {
  background: #2D3926; border-radius: 16rpx;
  padding: 30rpx 0; text-align: center;
  font-size: 30rpx; color: #F3E8D4; font-weight: 500;
}
.submit-btn.disabled { background: rgba(200,184,175,0.4); }

.success { display: flex; flex-direction: column; align-items: center; padding-top: 100rpx; gap: 24rpx; }
.success-icon { font-size: 80rpx; }
.success-text { font-size: 32rpx; color: #2A1F10; }

.row { display: flex; gap: 20rpx; margin-top: 12rpx; }
.again-btn, .back-btn {
  background: rgba(255,252,247,0.85); border-radius: 16rpx;
  padding: 22rpx 40rpx; font-size: 28rpx;
  border: 1rpx solid rgba(42,31,16,0.1);
}
.again-btn { color: #2D3926; }
.back-btn  { color: #9E8B7E; }
