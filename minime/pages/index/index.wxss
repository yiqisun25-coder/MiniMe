.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 72rpx 32rpx 160rpx;
  box-sizing: border-box;
}

/* ── 头像 ── */
.avatar-wrap {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx solid rgba(42, 31, 16, 0.12);
  box-shadow: 0 4rpx 20rpx rgba(42, 31, 16, 0.1);
}
.avatar { width: 100%; height: 100%; }

/* ── 问候语 ── */
.greeting {
  margin-top: 28rpx;
  font-size: 44rpx;
  color: #2A1F10;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* ── 场景回应文字 ── */
.subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #8A7A68;
  letter-spacing: 0.5rpx;
  text-align: center;
  line-height: 1.7;
  transition: opacity 0.25s ease;
}
.subtitle.visible { opacity: 1; }
.subtitle.hidden  { opacity: 0; }

/* ── 场景卡片网格 ── */
.scenes {
  margin-top: 40rpx;
  display: flex;
  flex-wrap: wrap;
  width: 100%;
  justify-content: space-between;
}

.scene-card {
  width: 335rpx;
  margin-bottom: 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(42, 31, 16, 0.07);
  box-shadow: 0 2rpx 10rpx rgba(42, 31, 16, 0.05);
  box-sizing: border-box;
}

.scene-img-area {
  height: 180rpx;
  background: #F5F0E8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scene-card.active .scene-img-area {
  background: #2D3926;
}

.scene-emoji { font-size: 72rpx; }

.scene-text-area {
  padding: 20rpx 24rpx 26rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.scene-label {
  font-size: 28rpx;
  color: #2A1F10;
  font-weight: 600;
}

.scene-desc {
  font-size: 22rpx;
  color: #9E8B7E;
  line-height: 1.5;
}

.scene-card.active .scene-label { color: #2D3926; }
.scene-card.active .scene-desc  { color: #7A8A76; }

/* ── 给你的信 ── */
.letter-entry {
  width: 100%;
  box-sizing: border-box;
  margin-top: 24rpx;
  background: #FFFCF7;
  border-radius: 20rpx;
  border: 1rpx solid rgba(42, 31, 16, 0.08);
  box-shadow: 0 2rpx 12rpx rgba(42, 31, 16, 0.05);
  padding: 32rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.letter-entry-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
  min-width: 0;
}

.letter-entry-icon { font-size: 52rpx; }

.letter-entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2A1F10;
}

.letter-badge {
  min-width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #C4706A;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  flex-shrink: 0;
}

.letter-badge-num {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.letter-entry-arrow {
  font-size: 40rpx;
  color: #C8B8AF;
  flex-shrink: 0;
}
